# Purpose: Template environment variables for local Supabase and Vite setup.
# Used by: Developers configuring the app locally.
# Main dependencies: Vite env loader and Supabase client bootstrap.
# Public/main values: `VITE_ENABLE_SUPABASE`, `VITE_SUPABASE_URL`, `VITE_SUPABASE_ANON_KEY`.
# Important side effects: None. Copy to `.env.local` for actual local use.
VITE_ENABLE_SUPABASE=false
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
