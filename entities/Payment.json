{
  "name": "Payment",
  "type": "object",
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Invoice number"
    },
    "registration_id": {
      "type": "string"
    },
    "participant_name": {
      "type": "string"
    },
    "participant_email": {
      "type": "string"
    },
    "program_name": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "bank_transfer",
        "credit_card",
        "invoice",
        "other"
      ],
      "default": "bank_transfer"
    },
    "payment_date": {
      "type": "string",
      "format": "date"
    },
    "payment_proof_url": {
      "type": "string",
      "description": "Payment proof file"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ],
      "default": "pending"
    },
    "verified_by": {
      "type": "string"
    },
    "verified_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "registration_id",
    "amount"
  ]
}